# MQTT Broker Configuration
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=Carl
MQTT_BROKER_PASSWORD=ControlsOT
MQTT_CLIENT_ID=uns-payload-all
MQTT_KEEPALIVE=60
MQTT_QOS=1

# MQTT Topic Configuration
MQTT_BASE_TOPIC=acme/orange-county/stamping/press-line-4/can-press-1
MQTT_TOPIC_PREFIX=acme

# Asset Configuration
ASSET_ID=201
ASSET_NAME=can-press-1
ASSET_DESCRIPTION=Can press for stamping operations

# Publisher Configuration
PUBLISH_INTERVAL=30
SIMULATION_MODE=true
LOG_LEVEL=INFO

# Optional: TLS/SSL Configuration
MQTT_USE_TLS=false
MQTT_CA_CERT_PATH=path/to/ca.crt
MQTT_CLIENT_CERT_PATH=path/to/client.crt
MQTT_CLIENT_KEY_PATH=path/to/client.key

# Optional: Authentication
MQTT_USE_AUTH=false
